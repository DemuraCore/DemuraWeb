---
import "../style/base.css";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="DemuraAI Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="text-p5-white">
    <!-- Transition Overlay -->
    <div id="p5-transition-overlay"></div>

    <main class="relative z-10" id="main-content">
      <slot />
    </main>

    <audio id="background-music" src="/music.wav" loop transition:persist
    ></audio>
    <Footer />

    <!-- GSAP for 2.5D Animations -->
    <script>
      import gsap from "gsap";

      // Audio Logic
      window.addEventListener("DOMContentLoaded", function () {
        const audio = document.getElementById(
          "background-music",
        ) as HTMLAudioElement;
        if (!audio) return;
        const playAudio = () => {
          audio.play().catch(() => {});
          ["click", "keydown", "touchstart"].forEach((e) =>
            window.removeEventListener(e, playAudio),
          );
        };
        ["click", "keydown", "touchstart"].forEach((e) =>
          window.addEventListener(e, playAudio),
        );
      });

      // P5 Red Wipe View Transition
      document.addEventListener("astro:before-preparation", (ev) => {
        ev.preventDefault(); // Stop default Astro swap
        const originalLoader = ev.loader;

        ev.loader = async function () {
          // 1. Animate red block IN
          await new Promise((r) =>
            gsap.to("#p5-transition-overlay", {
              y: "0%",
              rotation: -5,
              duration: 0.4,
              ease: "power4.inOut",
              onComplete: r,
            }),
          );

          // 2. Load next page content
          await originalLoader();

          // 3. Animate red block OUT
          gsap.to("#p5-transition-overlay", {
            y: "-120%",
            rotation: 15,
            duration: 0.5,
            ease: "power4.in",
            onComplete: () => {
              gsap.set("#p5-transition-overlay", { y: "100%", rotation: 15 });
            },
          });
        };
      });
    </script>
