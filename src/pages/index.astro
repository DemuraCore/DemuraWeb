<script>
  import gsap from "gsap";

  let destroyListeners: (() => void)[] = [];

  document.addEventListener("astro:page-load", () => {
    destroyListeners.forEach((destroy) => destroy());
    destroyListeners = [];

    const cameraRig = document.getElementById("camera-rig");
    const floatingShapes =
      document.querySelectorAll<HTMLElement>(".floating-shape");
    const redBg = document.getElementById("red-angle-bg");

    // --- 1. Dynamic Parallax Mouse Tracking ---
    const handleMouseMove = (e: MouseEvent) => {
      const { innerWidth, innerHeight } = window;
      const xPos = e.clientX / innerWidth - 0.5;
      const yPos = e.clientY / innerHeight - 0.5;

      if (cameraRig) {
        gsap.to(cameraRig, {
          duration: 0.5,
          rotationY: xPos * 30,
          rotationX: yPos * -30,
          transformPerspective: 1500,
          transformOrigin: "center center",
          ease: "power1.out",
        });
      }

      floatingShapes.forEach((shape) => {
        const speed = parseFloat(shape.getAttribute("data-speed") || "1");
        gsap.to(shape, {
          duration: 0.8,
          x: xPos * 80 * speed,
          y: yPos * 80 * speed,
          rotation: xPos * 25,
          ease: "power1.out",
        });
      });

      if (redBg) {
        gsap.to(redBg, {
          duration: 1,
          x: xPos * -50,
          y: yPos * -50,
          rotation: -6 + xPos * 6,
          ease: "power1.out",
        });
      }
    };

    window.addEventListener("mousemove", handleMouseMove);
    destroyListeners.push(() =>
      window.removeEventListener("mousemove", handleMouseMove),
    );

    // --- 2. Initial Staggered 3D Burst Load Animation ---
    const tl = gsap.timeline();

    gsap.set(".logo-container", {
      z: -1000,
      y: 300,
      opacity: 0,
      rotationX: 120,
      rotationY: 45,
      scale: 0.2,
      skewX: 0,
    });
    gsap.set(".menu-list button", {
      x: "-120%",
      z: 200,
      opacity: 0,
      skewX: 45,
      rotationZ: 10,
    });
    gsap.set("#red-angle-bg", { scaleY: 0, transformOrigin: "0% 0%" });
    gsap.set(".floating-shape", { scale: 0, rotation: -180, opacity: 0 });

    tl.to("#red-angle-bg", {
      scaleY: 1,
      duration: 0.7,
      ease: "expo.out",
    })
      .to(
        ".logo-container",
        {
          z: 50,
          y: 0,
          opacity: 1,
          rotationX: 0,
          rotationY: 0,
          scale: 1,
          skewX: -8,
          duration: 1.2,
          ease: "elastic.out(1, 0.4)",
        },
        "-=0.2",
      )
      .to(
        ".menu-list button",
        {
          x: "0%",
          z: 0,
          opacity: 1,
          skewX: 0,
          rotationZ: 0,
          stagger: 0.1,
          duration: 0.7,
          ease: "back.out(1.5)",
        },
        "-=0.9",
      )
      .to(
        ".floating-shape",
        {
          scale: 1,
          rotation: 0,
          opacity: 1,
          duration: 1.5,
          stagger: 0.15,
          ease: "elastic.out(1.2, 0.4)",
        },
        "-=1.0",
      );

    // --- 3. DYNAMIC MULTI-TRANSITION ROUTER ---
    let isTransitioning = false;
    const navButtons = document.querySelectorAll(".nav-btn");

    navButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        if (isTransitioning) return;
        isTransitioning = true;

        const targetId = btn.getAttribute("data-nav-target");
        if (!targetId) return;

        const currentActiveView = Array.from(
          document.querySelectorAll(".page-view"),
        ).find((el) => window.getComputedStyle(el).display !== "none");
        const targetView = document.getElementById(targetId);

        if (
          !currentActiveView ||
          !targetView ||
          currentActiveView.id === targetId
        ) {
          isTransitioning = false;
          return;
        }

        const transTl = gsap.timeline({
          onComplete: () => {
            isTransitioning = false;
          },
        });

        // Universal P5 Hit impact (Camera Shake and Screen Flash)
        transTl
          .to("#scene-container", {
            x: () => gsap.utils.random(-35, 35),
            y: () => gsap.utils.random(-35, 35),
            duration: 0.05,
            yoyo: true,
            repeat: 5,
          })
          .to(
            "#flash-overlay",
            {
              opacity: 0.9,
              duration: 0.05,
              yoyo: true,
              repeat: 1,
            },
            0,
          );

        // Core View Swapping Logic
        const targetElements = targetView.querySelectorAll(
          ".view-content, .logo-container, .nav-btn, .menu-list button, .roster-item, .roster-details, .profile-menu-item, .profile-details-container, .mission-item, .mission-details-container",
        );
        const swapViews = () => {
          gsap.set(currentActiveView, {
            display: "none",
            opacity: 0,
            pointerEvents: "none",
          });
          gsap.set(targetView, {
            display: "flex",
            opacity: 1,
            pointerEvents: "auto",
          });
        };

        // --- UNIQUE TRANSITION BRANCHING ---
        switch (targetId) {
          case "view-party": // Selection Character Screen
            gsap.set(targetElements, {
              opacity: 0,
              scale: 0.5,
              rotationZ: 15,
              x: 200,
              skewX: 20,
              z: -400,
            });

            // 1. Jagged Summon Wipe In
            transTl
              .set(".summon-flash", { opacity: 1 }, 0)
              .to(".summon-flash", { opacity: 0, duration: 0.1 }, 0.1)
              .to(
                ".summon-star",
                { scale: 2, rotation: 90, duration: 0.4, ease: "power4.inOut" },
                0.1
              )
              .to(
                ".summon-star-inner",
                { scale: 2.2, rotation: -90, duration: 0.45, ease: "power4.inOut" },
                0.1
              )
              .set(".summon-text", { display: "block" }, 0.25)
              .to(
                ".summon-text",
                { opacity: 1, scale: 1.5, duration: 0.2, ease: "bounce.out" },
                0.25
              )
              // Swap!
              .add(swapViews, 0.5)
              // 2. Jagged Summon Wipe Out
              .to(
                ".summon-text",
                { opacity: 0, scale: 0.5, duration: 0.15, ease: "power3.in" },
                0.6
              )
              .set(".summon-text", { display: "none" }, 0.75)
              .to(
                ".summon-star",
                { scale: 0, rotation: 180, duration: 0.4, ease: "power4.inOut" },
                0.65
              )
              .to(
                ".summon-star-inner",
                { scale: 0, rotation: -180, duration: 0.45, ease: "power4.inOut" },
                0.65
              )

              // 3. Enter left list
              .to(
                targetView.querySelectorAll(".roster-item, .nav-btn"),
                {
                  opacity: 1,
                  x: 0,
                  scale: 1,
                  rotationZ: 0,
                  skewX: 0,
                  z: 0,
                  stagger: 0.1,
                  duration: 0.6,
                  ease: "back.out(2)",
                },
                0.8,
              )
              // 4. Enter right polygon details
              .to(
                ".roster-details",
                {
                  opacity: 1,
                  x: 0,
                  scale: 1,
                  rotationZ: 0,
                  skewX: 0,
                  z: 0,
                  duration: 0.8,
                  ease: "elastic.out(1, 0.6)",
                },
                0.9,
              );
            break;

          case "view-projects":
            gsap.set(targetElements, {
              opacity: 0,
              z: -600,
              scale: 0.4,
              rotationX: 60,
              y: 200,
              skewX: 0,
            });

            // 1. The Slash Enter
            transTl
              .set(".slash-bg", { opacity: 1 }, 0)
              .to(".slash-bg", { opacity: 0, duration: 0.1 }, 0.1)
              .to(
                ".slice-block, .slice-block-shadow",
                { y: "0%", duration: 0.35, ease: "power4.inOut" },
                0.1,
              )
              .set(".slice-text", { display: "block" }, 0.25)
              .to(
                ".slice-text",
                { opacity: 1, scale: 1.2, duration: 0.2, ease: "bounce.out" },
                0.25,
              )
              // Swap!
              .add(swapViews, 0.45)
              // 2. The Slash Exit
              .to(
                ".slice-text",
                { opacity: 0, scale: 0.5, duration: 0.15, ease: "power3.in" },
                0.55,
              )
              .set(".slice-text", { display: "none" }, 0.7)
              .to(
                ".slice-block",
                { y: "150%", duration: 0.4, ease: "power4.inOut" },
                0.65,
              )
              .to(
                ".slice-block-shadow",
                { y: "150%", duration: 0.45, ease: "power4.inOut" },
                0.65,
              )
              // 3. Projects View Boom Enter
              .to(
                targetElements,
                {
                  opacity: 1,
                  z: 0,
                  scale: 1,
                  rotationX: 0,
                  y: 0,
                  stagger: 0.1,
                  duration: 0.8,
                  ease: "elastic.out(1, 0.6)",
                },
                0.7,
              )
              .set(".slice-block", { y: "-150%" }, "+=0.1");
            break;

          case "view-profile":
            gsap.set(targetElements, {
              opacity: 0,
              x: -400,
              skewX: 30,
              scale: 0.8,
              rotationY: 0,
            });

            // 1. Diagonal Wipe Enter
            transTl
              .to(
                ".profile-slice-top",
                { y: "0%", duration: 0.35, ease: "power4.inOut" },
                0.1,
              )
              .to(
                ".profile-slice-bottom",
                { y: "0%", duration: 0.35, ease: "power4.inOut" },
                0.1,
              )
              .set(".profile-text", { display: "block" }, 0.25)
              .to(
                ".profile-text",
                { opacity: 1, scale: 1.2, duration: 0.2, ease: "bounce.out" },
                0.25,
              )
              // Swap!
              .add(swapViews, 0.45)
              // 2. Diagonal Wipe Exit
              .to(
                ".profile-text",
                { opacity: 0, scale: 0.5, duration: 0.15, ease: "power3.in" },
                0.55,
              )
              .set(".profile-text", { display: "none" }, 0.7)
              .to(
                ".profile-slice-top",
                { y: "-150%", duration: 0.4, ease: "power4.inOut" },
                0.65,
              )
              .to(
                ".profile-slice-bottom",
                { y: "150%", duration: 0.4, ease: "power4.inOut" },
                0.65,
              )
              // 3. Profile view slide-snap in
              .to(
                targetElements,
                {
                  opacity: 1,
                  x: 0,
                  skewX: 0,
                  scale: 1,
                  stagger: 0.1,
                  duration: 0.7,
                  ease: "back.out(1.4)",
                },
                0.6,
              );
            break;

          case "view-contact":
            gsap.set(targetElements, {
              opacity: 0,
              rotationZ: -45, // more aggressive angle
              scale: 0.5,
              z: -500,
              y: 200,
              x: -100,
            });

            // 1. Expanding Calling Card graphic
            transTl
              .to(
                ".contact-bg",
                { opacity: 1, duration: 0.15, ease: "power2.in" },
                0,
              )
              .to(
                ".contact-circle",
                {
                  scale: 2,
                  rotation: 135,
                  duration: 0.5,
                  ease: "power4.inOut",
                }, // Smooth spin scaling in
                0.05,
              )
              .to(
                ".contact-text",
                { opacity: 1, scale: 1.5, duration: 0.3, ease: "back.out(2)" }, // Pop out text
                0.25,
              )
              // Swap!
              .add(swapViews, 0.6)
              // 2. Shrinking back
              .to(".contact-bg", { opacity: 0, duration: 0.3 }, 0.65)
              .to(
                ".contact-text",
                { opacity: 0, scale: 0.5, duration: 0.2 },
                0.65,
              )
              .to(
                ".contact-circle",
                { scale: 0, rotation: 225, duration: 0.5, ease: "expo.in" }, // Smooth spin scaling out
                0.65,
              )
              // 3. Spin down drop-in
              .to(
                targetElements,
                {
                  opacity: 1,
                  rotationZ: 0,
                  scale: 1,
                  z: 0,
                  x: 0,
                  y: 0,
                  stagger: 0.1,
                  duration: 0.8,
                  ease: "elastic.out(1, 0.5)",
                },
                0.75,
              );
            break;

          case "view-home":
            gsap.set(targetElements, {
              opacity: 0,
              y: -400,
              rotationX: -60,
              scale: 0.8,
              x: 0,
              skewX: 0,
              z: 0,
            });

            // 1. Screen tearing
            transTl
              .to(
                ".glitch-stripe",
                { y: "0%", stagger: 0.05, duration: 0.25, ease: "power2.out" },
                0.1,
              )
              // Swap!
              .add(swapViews, 0.4)
              // 2. Tear away alternating
              .to(
                ".glitch-stripe",
                {
                  y: (i) => (i % 2 === 0 ? "100%" : "-100%"),
                  stagger: 0.05,
                  duration: 0.35,
                  ease: "power3.in",
                },
                0.5,
              )
              // 3. Fall into place
              .to(
                targetElements,
                {
                  opacity: 1,
                  y: 0,
                  rotationX: 0,
                  scale: 1,
                  stagger: 0.08,
                  duration: 0.8,
                  ease: "back.out(1.5)",
                },
                0.6,
              )
              // reset tears
              .set(
                ".glitch-stripe",
                { y: (i) => (i % 2 === 0 ? "-100%" : "100%") },
                "+=0.1",
              );
            break;
        }
      });
    });

    // --- 4. Profile Sub-Menu Logic (Menu inside Menu) ---
    const profileMenuItems = document.querySelectorAll(".profile-menu-item");
    profileMenuItems.forEach((item) => {
      item.addEventListener("click", () => {
        const targetId = item.getAttribute("data-target");
        if (!targetId) return;

        const targetPanel = document.getElementById(targetId);
        if (!targetPanel || targetPanel.style.display !== "none") return;

        // Update active class
        profileMenuItems.forEach(i => {
          i.classList.remove("bg-p5-red", "text-p5-white");
          i.classList.add("bg-p5-white", "text-p5-black");
        });
        item.classList.remove("bg-p5-white", "text-p5-black");
        item.classList.add("bg-p5-red", "text-p5-white");

        const currentActivePanel = document.querySelector(".profile-content-panel:not([style*='display: none'])");

        const tl = gsap.timeline();

        // Hide current
        if (currentActivePanel) {
           tl.to(currentActivePanel, {
             opacity: 0,
             x: -50,
             duration: 0.2,
             ease: "power2.in",
             onComplete: () => {
               (currentActivePanel as HTMLElement).style.display = "none";
               (currentActivePanel as HTMLElement).style.pointerEvents = "none";
             }
           });
        }

        // Show new (Slice in like P3/P5 menus)
        tl.set(targetPanel, { display: "flex", opacity: 0, x: 100, clipPath: "polygon(0 0, 0 0, 0 100%, 0% 100%)", pointerEvents: "auto" })
          .to(targetPanel, {
            opacity: 1,
            x: 0,
            clipPath: "polygon(0 0, 100% 0, 100% 100%, 0% 100%)",
            duration: 0.5,
            ease: "power4.out"
          });
      });
    });

    // --- 4.5 Personas Sub-Menu Logic ---
    const rosterItems = document.querySelectorAll(".roster-item");
    rosterItems.forEach((item) => {
      item.addEventListener("click", () => {
        const targetId = item.getAttribute("data-persona");
        if (!targetId) return;

        const targetPanel = document.getElementById(targetId);
        if (!targetPanel || targetPanel.style.display !== "none") return;

        // Update active class
        rosterItems.forEach(i => {
          i.classList.remove("bg-p5-red", "text-p5-white");
          i.classList.add("bg-p5-white", "text-p5-black");
        });
        item.classList.remove("bg-p5-white", "text-p5-black");
        item.classList.add("bg-p5-red", "text-p5-white");

        const currentActivePanel = document.querySelector(".persona-panel:not([style*='display: none'])");

        const tl = gsap.timeline();

        // Hide current
        if (currentActivePanel) {
           tl.to(currentActivePanel, {
             opacity: 0,
             scale: 0.9,
             duration: 0.2,
             ease: "power2.in",
             onComplete: () => {
               (currentActivePanel as HTMLElement).style.display = "none";
               (currentActivePanel as HTMLElement).style.pointerEvents = "none";
             }
           });
        }

        // Show new (Burst in like Persona summoning)
        tl.set(targetPanel, { display: "block", opacity: 0, scale: 1.1, pointerEvents: "auto" })
          .to(targetPanel, {
            opacity: 1,
            scale: 1,
            duration: 0.4,
            ease: "back.out(2)"
          });
      });
    });

    // --- 4.7 Missions Sub-Menu Logic ---
    const missionItems = document.querySelectorAll(".mission-item");
    missionItems.forEach((item) => {
      item.addEventListener("click", () => {
        const targetId = item.getAttribute("data-mission");
        if (!targetId) return;

        const targetPanel = document.getElementById(targetId);
        if (!targetPanel || targetPanel.style.display !== "none") return;

        // Update active class
        missionItems.forEach(i => {
          i.classList.remove("bg-p5-white", "text-p5-black");
          i.classList.add("bg-p5-gray", "text-white");
        });
        item.classList.remove("bg-p5-gray", "text-white");
        item.classList.add("bg-p5-white", "text-p5-black");

        const currentActivePanel = document.querySelector(".mission-panel:not([style*='display: none'])");

        const tl = gsap.timeline();

        // Hide current
        if (currentActivePanel) {
           tl.to(currentActivePanel, {
             opacity: 0,
             y: -50,
             skewX: 10,
             duration: 0.25,
             ease: "power2.in",
             onComplete: () => {
               (currentActivePanel as HTMLElement).style.display = "none";
               (currentActivePanel as HTMLElement).style.pointerEvents = "none";
             }
           });
        }

        // Show new (Diagonal slice drop in)
        tl.set(targetPanel, { display: "flex", opacity: 0, y: 50, skewX: -10, pointerEvents: "auto" })
          .to(targetPanel, {
            opacity: 1,
            y: 0,
            skewX: 0,
            duration: 0.5,
            ease: "back.out(1.5)"
          });
      });
    });

    // --- 5. Glitch Effect Hover ---
    const glitchItems = document.querySelectorAll(
      ".glitch-item span, .glitch-item",
    );
    const possibleChars =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789/;[]=-~!@#$%^&*()+{}:?><€¡¥×«»¶¿çµñ©æáßðøöóíúüþéåä";

    glitchItems.forEach((item) => {
      if (item.tagName !== "SPAN") return;
      const originalText = item.textContent ? item.textContent.trim() : "";
      let timeouts: (number | undefined)[] = [];

      const parentNode = item.closest(".glitch-item");
      parentNode?.addEventListener("mouseenter", () => {
        const charArr = originalText.split("");
        const strength = Math.ceil(charArr.length / 4);

        const times = 10 * (400 / 1000);
        for (let i = 0; i < times; i++) {
          const speed = 1000 / 12;
          timeouts.push(
            setTimeout(() => {
              for (let j = 0; j < strength; j++) {
                const randChar = possibleChars.charAt(
                  Math.floor(Math.random() * possibleChars.length),
                );
                const index = Math.floor(Math.random() * charArr.length);
                charArr[index] = randChar;
                item.textContent = charArr.join("");
              }
            }, i * speed),
          );
        }
        timeouts.push(
          setTimeout(
            () => {
              item.textContent = originalText;
            },
            times * (1000 / 12),
          ),
        );
      });

      parentNode?.addEventListener("mouseleave", () => {
        timeouts.forEach((t) => clearTimeout(t));
        item.textContent = originalText;
      });
    });
  });
</script>
