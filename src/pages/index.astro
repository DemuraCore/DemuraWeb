import Layout from "../layouts/Layout.astro";
---

<Layout title="DemuraAI">
  <!-- P5 Angular Background Element -->
  <div
    class="fixed inset-0 z-0 overflow-hidden pointer-events-none"
    id="bg-parallax"
  >
    <div
      class="absolute top-[-30%] left-[-20%] w-[180%] h-[90%] bg-p5-red transform -rotate-6 origin-top-left border-b-[40px] border-p5-black shadow-2xl skew-y-3 transition-transform duration-[600ms] ease-out"
      id="red-angle-bg"
    >
    </div>
    <div
      class="absolute top-[20%] right-[10%] w-64 h-64 border-[25px] border-black/20 rounded-full floating-shape transition-transform duration-[800ms] ease-out"
      data-speed="-1.5"
    >
    </div>
    <div
      class="absolute bottom-[10%] left-[5%] w-80 h-80 bg-white/5 transform rotate-45 floating-shape transition-transform duration-[900ms] ease-out"
      data-speed="2"
    >
    </div>
    <div
      class="absolute top-[70%] right-[15%] w-96 h-16 bg-black/40 transform -skew-x-12 floating-shape transition-transform duration-[700ms] ease-out"
      data-speed="1.2"
    >
    </div>
    <div
      class="absolute top-[10%] left-[40%] w-32 h-32 border-[10px] border-p5-red/30 transform rotate-[30deg] floating-shape transition-transform duration-[1000ms] ease-out"
      data-speed="-0.8"
    >
    </div>
  </div>

  <!-- SPA Multi-Transitions Container -->
  <div
    id="flash-overlay"
    class="fixed inset-0 bg-p5-white z-[9999] pointer-events-none opacity-0 mix-blend-overlay"
  >
  </div>

  <div
    id="transition-layers"
    class="fixed inset-0 z-[9998] pointer-events-none overflow-hidden"
  >
    <!-- 1. The Slash (Used for Projects) -->
    <div
      id="trans-slash"
      class="absolute inset-0 flex items-center justify-center pointer-events-none"
    >
      <!-- Background white flash -->
      <div class="absolute inset-0 bg-p5-white opacity-0 slash-bg z-0"></div>
      <div
        class="bg-p5-black w-[250%] h-[200%] transform -translate-y-[150%] rotate-[-35deg] shadow-[0_0_80px_rgba(230,0,18,1)] border-b-[80px] border-p5-red slice-block z-10"
        style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 4vw), 0 100%);"
      >
      </div>
      <div
        class="bg-p5-red w-[250%] h-[200%] transform -translate-y-[150%] rotate-[-35deg] slice-block-shadow z-0 absolute"
        style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 4vw), 0 100%); margin-top: 20px"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-p5-white font-display text-9xl tracking-widest uppercase opacity-0 slice-text skew-x-[-15deg] whitespace-nowrap hidden z-20 mix-blend-difference drop-shadow-[5px_5px_0_rgba(230,0,18,1)]"
      >
        TAKE YOUR HEART
      </div>
    </div>

    <!-- 2. Diagonal Wipe (Used for Profile) -->
    <div
      id="trans-profile"
      class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden z-[9999]"
    >
      <div
        class="profile-slice-top absolute w-[200%] h-[150%] bg-p5-red transform origin-bottom-left -translate-y-[150%] rotate-[-25deg] shadow-[0_0_80px_rgba(0,0,0,1)] border-b-[60px] border-p5-black z-10"
      >
      </div>
      <div
        class="profile-slice-bottom absolute w-[200%] h-[150%] bg-p5-black transform origin-top-right translate-y-[150%] rotate-[-25deg] shadow-[0_0_80px_rgba(230,0,18,0.8)] border-t-[60px] border-p5-red z-10"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-p5-white font-display text-9xl tracking-widest uppercase opacity-0 profile-text skew-x-[-15deg] whitespace-nowrap hidden z-20 mix-blend-difference drop-shadow-[5px_5px_0_rgba(230,0,18,1)]"
      >
        STATUS
      </div>
    </div>

    <!-- 3. The Call Card Expand (Used for Contact) -->
    <div
      id="trans-contact"
      class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden z-[9999]"
    >
      <div
        class="absolute inset-0 bg-p5-red opacity-0 contact-bg z-0 pointer-events-none"
      >
      </div>
      <div
        class="contact-circle absolute w-[150vw] h-[150vw] sm:w-[100vw] sm:h-[100vw] bg-p5-black rotate-45 scale-0 flex flex-col items-center justify-center border-[20px] sm:border-[40px] border-p5-white z-10 pointer-events-none origin-center"
      >
      </div>
      <span
        class="text-p5-white font-display text-4xl sm:text-9xl opacity-0 contact-text transform -rotate-12 absolute whitespace-nowrap z-20 drop-shadow-[4px_4px_0_#e60012] mix-blend-difference pointer-events-none"
      >
        WE WILL TAKE YOUR HEART
      </span>
    </div>

    <!-- 4. The Glitch Stripes (Used for Return to Home) -->
    <div
      id="trans-home"
      class="absolute inset-0 flex pointer-events-none z-[9999]"
    >
      <div
        class="glitch-stripe w-1/5 h-[120%] bg-p5-black transform -translate-y-full border-r-[25px] border-p5-red skew-x-12"
      >
      </div>
      <div
        class="glitch-stripe w-1/5 h-[120%] bg-p5-white transform translate-y-full border-r-[25px] border-p5-black -skew-x-12"
      >
      </div>
      <div
        class="glitch-stripe w-1/5 h-[120%] bg-p5-red transform -translate-y-full border-r-[25px] border-p5-white skew-x-12"
      >
      </div>
      <div
        class="glitch-stripe w-1/5 h-[120%] bg-p5-black transform translate-y-full border-r-[25px] border-p5-red -skew-x-12"
      >
      </div>
      <div
        class="glitch-stripe w-1/5 h-[120%] bg-p5-white transform -translate-y-full border-r-[25px] border-p5-red skew-x-12"
      >
      </div>
    </div>

    <!-- 5. Jagged Summon Wipe (Used for Personas) -->
    <div
      id="trans-party"
      class="absolute inset-0 flex items-center justify-center pointer-events-none overflow-hidden z-[9999]"
    >
      <div class="absolute inset-0 bg-p5-white opacity-0 summon-flash z-0"></div>

      <!-- Jagged center spin -->
      <div
        class="summon-star absolute w-[150vw] h-[150vw] sm:w-[100vw] sm:h-[100vw] bg-p5-black border-[30px] border-p5-red origin-center z-10"
        style="clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%); transform: scale(0) rotate(0deg);"
      >
      </div>
      <div
        class="summon-star-inner absolute w-[150vw] h-[150vw] sm:w-[100vw] sm:h-[100vw] bg-p5-red origin-center z-10 mix-blend-screen"
        style="clip-path: polygon(50% 10%, 58% 40%, 90% 40%, 64% 58%, 73% 85%, 50% 68%, 27% 85%, 36% 58%, 10% 40%, 42% 40%); transform: scale(0) rotate(45deg);"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-p5-white font-display text-9xl tracking-widest uppercase opacity-0 summon-text skew-x-[-15deg] whitespace-nowrap hidden z-20 mix-blend-difference drop-shadow-[5px_5px_0_rgba(230,0,18,1)]"
      >
        PERSONA
      </div>
    </div>
  </div>

  <!-- 3D Scene Rig -->
  <div
    class="relative z-10 flex flex-col items-center justify-center h-screen mx-5 transform-gpu"
    id="scene-container"
    style="perspective: 1500px;"
  >
    <div
      id="camera-rig"
      class="w-full h-full flex flex-col items-center flex-1 justify-center transition-transform duration-[200ms] ease-out"
      style="transform-style: preserve-3d;"
    >
      <!-- ============================================== -->
      <!-- VIEW: MAIN MENU                                -->
      <!-- ============================================== -->
      <div
        id="view-home"
        class="page-view absolute inset-0 flex flex-col items-center justify-center w-full h-full"
      >
        <!-- Logo -->
        <div
          class="logo-container relative w-64 sm:w-96 mb-12 origin-bottom p-6 bg-p5-black border-[6px] border-p5-white shadow-[20px_20px_0px_0px_#e60012]"
          style="transform: translateZ(80px) skewX(-8deg);"
        >
          <svg
            id="Layer_2"
            data-name="Layer 2"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 864.8 206.2"
            class="w-full text-white fill-white"
            style="filter: drop-shadow(6px 6px 0px rgba(255,255,255,0.3));"
          >
            <g id="Layer_1-2" data-name="Layer 1">
              <g>
                <g>
                  <path
                    d="m779.1,147.2l-30.6-86-30.4,86h-30.2l42.6-120h36.3l42.6,120h-30.2Z"
                    style="fill: currentColor; stroke-width: 0px;"></path>
                  <path
                    d="m852.1,147.2h-28.1V26.7h28.1v120.5Z"
                    style="fill: currentColor; stroke-width: 0px;"></path>
                </g>
                <g>
                  <path
                    d="m29.8,147.4H4.8V27.5h81.2c4.5,0,8.8,1.6,12.8,4.7,4,3.1,7.5,7.4,10.5,12.9,3,5.4,5.4,11.8,7.1,19,1.7,7.3,2.6,15,2.6,23.2s-.9,16-2.6,23.2c-1.7,7.3-4.1,13.6-7.1,19-3,5.4-6.5,9.7-10.5,12.9-4,3.1-8.3,4.7-12.8,4.7H29.7v.2Zm46.5-100.1H29.7v79.9h45.5c2.7,0,5.2-1.1,7.5-3.2,2.3-2.2,4.3-5.1,6-8.8,1.7-3.7,3-8,3.9-12.7.9-4.8,1.4-9.9,1.4-15.2s-.5-10.6-1.5-15.4c-1-4.8-2.3-9-4-12.7-1.7-3.6-3.6-6.5-5.7-8.6-2.1-2.1-4.3-3.2-6.6-3.2h0Z"
                    style="fill: currentColor; stroke-width: 0px;"></path>
                  <g>
                    <path
                      d="m179.9,148.5c-16.8,0-29.7-3.1-38.8-9.4-9.1-6.3-13.7-15.3-13.7-27.1s3.9-20.4,11.6-26.7c7.7-6.4,18.6-9.5,32.7-9.5s23.6,2.9,30.8,8.6c7.3,5.7,10.9,14.1,10.9,25s-.2,6.2-.6,9h-69v-10.7h51.7c0-6.3-2.1-11.2-6.3-14.5-4.2-3.4-10-5.1-17.4-5.1s-14.8,2-19.4,6.1c-4.6,4.1-6.9,9.8-6.9,17.2s3.2,14.3,9.5,18.5c6.3,4.2,15.3,6.4,27,6.4s8.1-.2,12.1-.5c4-.3,8-.8,12.1-1.4l2.4,12.3c-5.8.8-11.1,1.3-15.9,1.5-4.8.2-9.1.3-12.8.3Z"
                      style="fill: currentColor; stroke-width: 0px;"></path>
                    <path
                      d="m236.5,147.2v-70.2h17.4l2.2,14.8v55.4h-19.7Zm36.9,0v-55c0-4-2.6-6-7.8-6s-9.5,3.2-9.5,9.5l-5.7-10.1h6.3c.7-6.7,6.4-10.1,16.9-10.1s9.2,1.3,12.1,3.8c2.9,2.5,4.4,6.3,4.4,11.5v56.3h-16.7Zm33.9,0v-53.6c0-4.9-2.5-7.3-7.6-7.3s-9.6,3.2-9.6,9.5l-6.7-10.1h7.6c.3-2.7,1.8-5.1,4.6-7.1,2.7-2,6.7-3,11.9-3s11.7,1.3,14.8,3.9c3.1,2.6,4.6,6.8,4.6,12.6v55h-19.7Z"
                      style="fill: currentColor; stroke-width: 0px;"></path>
                    <path
                      d="m383.3,148.5c-10.3,0-18.3-2.2-24-6.6-5.7-4.4-8.5-10.6-8.5-18.6v-46.3h19.7v46.3c0,4,1.6,7.1,4.8,9.3,3.2,2.2,7.7,3.3,13.5,3.3s12.6-1.6,16.2-4.9c3.6-3.2,5.5-8.7,5.5-16.3l5,18.9h-6.5c-1.5,4.8-4.6,8.4-9.1,11-4.5,2.6-10.1,3.8-16.7,3.8Zm27.3-21.2v-50.3h19.7v46.3l-19.7,4Zm1.7,20.5l-1.7-16.8v-12.3h19.7v15.8l13.5,1.5v11.3l-31.5.7Z"
                      style="fill: currentColor; stroke-width: 0px;"></path>
                    <path
                      d="m456,147.2v-11.5h65.6v11.5h-65.6Zm3.7-58.7v-11.5h32.8l1.9,11.5h-34.7Zm18.2,58.7v-70.2h15.9l3.7,20.1v50.1h-19.7Zm19.7-30.2l-5.7-22h7.6c1.1-12.9,10.1-19.3,27.1-19.3s17.5,2.1,22.1,6.2c4.6,4.1,6.9,10.9,6.9,20.1h-19.5c0-5.1-1.1-8.8-3.2-11.1-2.1-2.3-5.6-3.4-10.3-3.4-8.3,0-14.6,2.5-18.7,7.6-4.1,5.1-6.2,12.3-6.2,21.8Z"
                      style="fill: currentColor; stroke-width: 0px;"></path>
                    <path
                      d="m601,148.5c-10.3,0-18.2-1.8-23.8-5.3-5.6-3.5-8.4-8.5-8.4-15s3.9-13.1,11.6-17.1c7.8-4,18.7-6,32.9-6s11.1.3,15.7.8c4.6.5,8.7,1.3,12.3,2.3l-4.1,9.5c-4.1-.7-8.2-1-12.1-1.2-4-.1-8-.2-12.1-.2-17.1,0-25.6,3.7-25.6,11.1s1.5,5.5,4.4,7.2c2.9,1.7,7.1,2.5,12.5,2.5s11.2-.8,15.3-2.3c4.1-1.5,7.2-3.4,9.2-5.8,2-2.3,3.1-4.7,3.1-7.2v-7.7l5.7,18h-7.8l3.2-2.1c0,4.1-1.3,7.4-3.9,10.2-2.6,2.7-6.3,4.7-11.1,6.1-4.8,1.3-10.4,2-16.9,2Zm34.7-.7l-1.3-20.8-2.6-5.8v-18.1c0-4.7-2.3-8.1-6.9-10.3-4.6-2.2-11.4-3.4-20.5-3.5l-23.5-.5,1.9-12.4,19.8.2c16.3.2,28.3,2.7,36.2,7.5s11.8,11.9,11.8,21.2v29.3l16.7,1.5v11.3l-31.5.7Z"
                      style="fill: currentColor; stroke-width: 0px;"></path>
                  </g>
                </g>
              </g>
            </g>
          </svg>
          <div
            class="absolute top-2 left-2 w-full h-full border-[6px] border-p5-red pointer-events-none -z-10 mix-blend-screen"
          >
          </div>
        </div>

        <!-- Menu Links -->
        <div class="menu-list flex flex-col gap-5 w-full max-w-sm items-center">
          <button
            data-nav-target="view-profile"
            class="nav-btn p5-shadow relative block w-[90%] bg-p5-white text-p5-black font-display text-4xl py-3 px-6 border-[5px] border-p5-black transform origin-center uppercase text-center overflow-hidden group glitch-item ml-[-30px]"
          >
            <span
              class="relative z-10 block transform -skew-x-12 group-hover:text-p5-white transition-colors duration-100"
              >Profile</span
            >
            <div
              class="absolute inset-0 bg-p5-red w-0 group-hover:w-full transition-all duration-300 ease-out z-0"
            >
            </div>
          </button>

          <button
            data-nav-target="view-party"
            class="nav-btn p5-shadow relative block w-[95%] bg-p5-white text-p5-black font-display text-4xl py-3 px-6 border-[5px] border-p5-black transform origin-center uppercase text-center overflow-hidden group glitch-item ml-[20px]"
          >
            <span
              class="relative z-10 block transform -skew-x-12 group-hover:text-p5-white transition-colors duration-100"
              >Personas</span
            >
            <div
              class="absolute inset-0 bg-p5-red w-0 group-hover:w-full transition-all duration-300 ease-out z-0"
            >
            </div>
          </button>

          <button
            data-nav-target="view-projects"
            class="nav-btn p5-shadow relative block w-full bg-p5-white text-p5-black font-display text-5xl py-4 px-6 border-[5px] border-p5-black transform origin-center uppercase text-center overflow-hidden group glitch-item ml-[-10px]"
          >
            <span
              class="relative z-10 block transform -skew-x-12 group-hover:text-p5-white transition-colors duration-100"
              >Missions</span
            >
            <div
              class="absolute inset-0 bg-p5-red w-0 group-hover:w-full transition-all duration-300 ease-out z-0"
            >
            </div>
          </button>

          <button
            data-nav-target="view-contact"
            class="nav-btn p5-shadow relative block w-[85%] bg-p5-white text-p5-black font-display text-3xl py-3 px-6 border-[5px] border-p5-black transform origin-center uppercase text-center overflow-hidden group glitch-item ml-[40px]"
          >
            <span
              class="relative z-10 block transform -skew-x-12 group-hover:text-p5-white transition-colors duration-100"
              >Connect</span
            >
            <div
              class="absolute inset-0 bg-p5-red w-0 group-hover:w-full transition-all duration-300 ease-out z-0"
            >
            </div>
          </button>
        </div>
      </div>

      <!-- ============================================== -->
      <!-- VIEW: PROFILE                                  -->
      <!-- ============================================== -->
      <div
        id="view-profile"
        class="page-view absolute inset-0 flex flex-row items-center justify-center w-full h-full opacity-0 pointer-events-none"
        style="display:none;"
      >
        <!-- Left: Profile Menu -->
        <div class="flex flex-col gap-4 w-1/3 max-w-[320px] z-20">
          <div
            class="profile-menu-item active bg-p5-red text-p5-white border-[5px] border-p5-black p-4 transform -skew-x-12 cursor-pointer hover:bg-p5-black hover:text-p5-white transition-colors p5-shadow"
            data-target="profile-identity"
          >
            <h3 class="font-display text-4xl uppercase">Identity</h3>
          </div>
          <div
            class="profile-menu-item bg-p5-white text-p5-black border-[5px] border-p5-black p-4 transform skew-x-6 cursor-pointer hover:bg-p5-red hover:text-p5-white transition-colors p5-shadow ml-6"
            data-target="profile-stats"
          >
            <h3 class="font-display text-4xl uppercase">Stats</h3>
          </div>
          <div
            class="profile-menu-item bg-p5-white text-p5-black border-[5px] border-p5-black p-4 transform -skew-x-6 cursor-pointer hover:bg-p5-red hover:text-p5-white transition-colors p5-shadow ml-[-10px]"
            data-target="profile-skills"
          >
            <h3 class="font-display text-4xl uppercase">Skills</h3>
          </div>
          <button
            class="nav-btn mt-10 block p5-shadow bg-p5-black text-p5-white font-display text-2xl py-3 px-6 uppercase hover:bg-p5-red hover:text-p5-white transition-colors transform -skew-x-12 w-3/4 border-[4px] border-p5-black"
            data-nav-target="view-home">Return</button
          >
        </div>

        <!-- Right: Profile Content Panel -->
        <div
          class="profile-details-container relative w-[45%] h-[65vh] bg-p5-white border-[8px] border-p5-black transform skew-x-[-3deg] shadow-[20px_20px_0px_#e60012] flex overflow-hidden ml-8"
        >
          <!-- Identity Content -->
          <div id="profile-identity" class="profile-content-panel absolute inset-0 p-10 flex flex-col justify-center">
            <h2
              class="font-display text-7xl uppercase mb-6 border-b-8 border-p5-red pb-2 inline-block text-p5-black"
            >
              Demura AI
            </h2>
            <p class="text-3xl font-black font-sans text-p5-black uppercase mb-2">
              Software Engineer
            </p>
            <p class="text-3xl font-black font-sans text-p5-red uppercase mb-2">
              Cloud Engineer
            </p>
            <p class="text-3xl font-black font-sans text-p5-gray uppercase">
              IoT Engineer
            </p>
            <div class="mt-8 bg-p5-black text-p5-white p-4 transform skew-x-6 inline-block self-start font-bold uppercase">
              Status: Active
            </div>
          </div>

          <!-- Stats Content -->
          <div id="profile-stats" class="profile-content-panel absolute inset-0 p-10 flex flex-col justify-center opacity-0 pointer-events-none" style="display:none;">
            <h2 class="font-display text-7xl uppercase mb-8 text-p5-red">Parameters</h2>
            <ul class="text-2xl mt-4 space-y-6 font-black font-sans uppercase">
              <li class="flex items-center gap-4">
                <span class="w-32">Logic</span>
                <div class="h-6 bg-p5-gray flex-grow border-2 border-p5-black"><div class="h-full bg-p5-red w-full"></div></div>
                <span>Max</span>
              </li>
              <li class="flex items-center gap-4">
                <span class="w-32">Creativity</span>
                <div class="h-6 bg-p5-gray flex-grow border-2 border-p5-black"><div class="h-full bg-p5-red w-4/5"></div></div>
                <span>Rank 4</span>
              </li>
              <li class="flex items-center gap-4">
                <span class="w-32">Guts</span>
                <div class="h-6 bg-p5-gray flex-grow border-2 border-p5-black"><div class="h-full bg-p5-red w-full"></div></div>
                <span>Max</span>
              </li>
              <li class="flex items-center gap-4">
                <span class="w-32">Efficiency</span>
                <div class="h-6 bg-p5-gray flex-grow border-2 border-p5-black"><div class="h-full bg-p5-red w-11/12"></div></div>
                <span>Rank 5</span>
              </li>
            </ul>
          </div>

          <!-- Skills Content -->
